  "ai_config_bool_true": "True",
  "ai_config_bool_false": "False",
  "ai_config_info_title": "Parameter Info",
  "ai_config_model_size_info": "Specifies the Whisper model size used for speech recognition.\n\nAvailable sizes:\n  tiny      — fastest, lowest accuracy\n  base      — fast, low accuracy\n  small     — balanced\n  medium    — good accuracy (recommended)\n  large-v3  — highest accuracy, slowest\n\nLarger models require more GPU memory and take longer to process. On CPU, 'small' or 'medium' is recommended.",
  "ai_config_language_info": "Source language of the audio as an ISO 639-1 code (e.g. 'en', 'de', 'ru').\n\nLeave empty for automatic language detection (default).\n\nSpecifying the language improves accuracy and speed when the source language is known in advance.",
  "ai_config_beam_size_info": "Number of beams used in beam search decoding.\n\nHigher values improve accuracy at the cost of speed.\n\nDefault: 5\nRecommended range: 1–10 (values above 10 have diminishing returns).",
  "ai_config_no_speech_info": "Probability threshold above which an audio segment is considered to contain no speech.\n\nIf the model's 'no speech' confidence exceeds this value, the segment is marked as bad audio and its text is replaced with XXXXX.\n\nDefault: 0.6\nRange: 0.0–1.0\n  Lower → more segments flagged as bad audio\n  Higher → more tolerant of noise",
  "ai_config_vad_info": "Enables Voice Activity Detection (VAD) pre-filtering.\n\nWhen True, silent portions of audio are removed before transcription. This reduces hallucinations on silent segments and can improve speed.\n\nDefault: False",
  "ai_config_word_ts_info": "When True, generates a timestamp for each individual word in addition to the segment-level timestamps.\n\nUseful for precise text-audio alignment.\n\nNote: Enabling this increases processing time.\n\nDefault: False",
  "ai_config_clustering_info": "Distance threshold used by the speaker clustering algorithm.\n\nControls how aggressively speakers are merged:\n  Lower value  → more distinct speakers identified\n  Higher value → fewer speakers (more merging)\n\nDefault: 0.715\nRecommended range: 0.5–0.9\n\nChanges take effect on the next session.",
  "ai_config_max_speakers_info": "Maximum number of speakers allowed in the output.\n\nSet to 0 for no limit (automatic detection).\n\nSetting an explicit value constrains the diarization and can improve accuracy when the number of speakers is known in advance.",

